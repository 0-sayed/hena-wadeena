{
  "name": "hena-wadeena",
  "version": "0.1.0",
  "private": true,
  "description": "Unified digital platform for New Valley Governorate, Egypt",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "lefthook install || true",
    "build:shared": "pnpm --filter @hena-wadeena/types build && pnpm --filter @hena-wadeena/nest-common build",
    "build:workspaces": "pnpm --filter @hena-wadeena/identity --filter @hena-wadeena/market --filter @hena-wadeena/guide-booking --filter @hena-wadeena/map --filter @hena-wadeena/web run build",
    "typecheck:workspaces": "pnpm --filter @hena-wadeena/types --filter @hena-wadeena/nest-common --filter @hena-wadeena/identity --filter @hena-wadeena/market --filter @hena-wadeena/guide-booking --filter @hena-wadeena/map --filter @hena-wadeena/web run typecheck",
    "test:workspaces": "pnpm --filter @hena-wadeena/types --filter @hena-wadeena/nest-common --filter @hena-wadeena/identity --filter @hena-wadeena/market --filter @hena-wadeena/guide-booking --filter @hena-wadeena/map --filter @hena-wadeena/web run test",
    "dev": "pnpm --filter @hena-wadeena/identity --filter @hena-wadeena/market --filter @hena-wadeena/guide-booking --filter @hena-wadeena/map run dev",
    "build": "pnpm run build:shared && pnpm run build:workspaces",
    "test": "pnpm run build:shared && pnpm run test:workspaces",
    "check": "pnpm run typecheck && npx eslint .",
    "lint": "eslint . && pnpm --filter @hena-wadeena/web run lint",
    "typecheck": "pnpm run build:shared && pnpm run typecheck:workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "validate": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm audit --audit-level=high",
    "db:seed": "pnpm --filter @hena-wadeena/identity run db:seed && pnpm --filter @hena-wadeena/market run db:seed && pnpm --filter @hena-wadeena/guide-booking run db:seed && pnpm --filter @hena-wadeena/map run db:seed",
    "db:seed:showcase": "pnpm --filter @hena-wadeena/identity run db:seed:showcase && pnpm --filter @hena-wadeena/market run db:seed:showcase && pnpm --filter @hena-wadeena/guide-booking run db:seed:showcase && pnpm --filter @hena-wadeena/map run db:seed:showcase"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@node-rs/argon2": "^2.0.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-orm": "^0.38.0",
    "eslint": "^9.20.0",
    "eslint-plugin-import": "^2.31.0",
    "knip": "^5.40.0",
    "lefthook": "^2.1.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.2",
      "lodash": "4.18.1",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "vite": ">=7.3.2"
    }
  }
}
