{
  "name": "hena-wadeena",
  "version": "0.1.0",
  "private": true,
  "description": "Unified digital platform for New Valley Governorate, Egypt",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter './services/*' run dev",
    "build": "pnpm --filter './packages/*' run build && pnpm --filter './services/*' run build",
    "test": "pnpm --filter './services/*' --filter './packages/*' run test",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm --filter './packages/*' --filter './services/*' run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm audit --audit-level=high && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-import": "^2.31.0",
    "knip": "^5.40.0",
    "prettier": "^3.4.2",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
