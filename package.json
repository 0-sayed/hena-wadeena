{
  "name": "hena-wadeena",
  "version": "0.1.0",
  "private": true,
  "description": "Unified digital platform for New Valley Governorate, Egypt",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "lefthook install || true",
    "dev": "pnpm --filter './services/*' run dev",
    "build": "pnpm --filter './packages/*' run build && pnpm --filter './services/*' run build && pnpm --filter './apps/*' run build",
    "test": "pnpm --filter './services/*' --filter './packages/*' --filter './apps/*' run test",
    "check": "pnpm --filter './packages/*' --filter './services/*' run typecheck && npx eslint .",
    "lint": "eslint . && pnpm --filter './apps/*' run lint",
    "typecheck": "pnpm --filter './packages/*' --filter './services/*' --filter './apps/*' run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "validate": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.20.0",
    "eslint-plugin-import": "^2.31.0",
    "knip": "^5.40.0",
    "lefthook": "^2.1.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.5.6",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4"
    }
  }
}
