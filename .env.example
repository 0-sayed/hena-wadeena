# ==============================================================
# Database
# ==============================================================
# PostgreSQL connection (all NestJS services share this)
DATABASE_URL=postgresql://hena:hena_dev@localhost:5432/wadeena_db
POSTGRES_USER=hena
POSTGRES_PASSWORD=hena_dev
POSTGRES_PORT=5432

# ==============================================================
# Redis
# ==============================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=
# Leave empty in dev (no auth), set in prod

# ==============================================================
# Authentication
# ==============================================================
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_in_production_access_secret_32chars
JWT_REFRESH_SECRET=change_me_in_production_refresh_secret_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==============================================================
# AI Service
# ==============================================================
GEMINI_API_KEY=your_gemini_api_key_here
# Models
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=hena_knowledge_base

# ==============================================================
# AWS S3
# ==============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=me-south-1
AWS_S3_BUCKET=hena-wadeena-uploads
# Presigned URL expiry (seconds)
AWS_S3_PRESIGNED_URL_EXPIRES=3600

# ==============================================================
# Email (Resend)
# ==============================================================
# Get your key at https://resend.com — free tier: 3k/month
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=noreply@hena-wadeena.com

# ==============================================================
# Service Ports (for local dev without Docker)
# ==============================================================
IDENTITY_PORT=8001
MARKET_PORT=8002
GUIDE_BOOKING_PORT=8003
MAP_PORT=8004
AI_PORT=8005
GATEWAY_PORT=8000

# ==============================================================
# Internal service URLs (used by services to call each other)
# Ports must match *_PORT values above
# ==============================================================
IDENTITY_SERVICE_URL=http://identity:8001
MARKET_SERVICE_URL=http://market:8002
GUIDE_BOOKING_SERVICE_URL=http://guide-booking:8003
MAP_SERVICE_URL=http://map:8004
AI_SERVICE_URL=http://ai:8005

# ==============================================================
# Rate Limiting
# ==============================================================
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Login endpoint: stricter (5 attempts per 60s)
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=5

# ==============================================================
# App
# ==============================================================
NODE_ENV=development
LOG_LEVEL=info
# Set to 1 when behind Nginx/ALB (required for correct IP in throttler)
TRUST_PROXY=1
