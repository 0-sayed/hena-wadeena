# ==============================================================
# Database
# ==============================================================
# PostgreSQL connection (all NestJS services share this)
# Format: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=
# Host-side URL for scripts that run outside Docker (db:reset, etc.)
# Same as DATABASE_URL but with localhost instead of the container hostname
DATABASE_URL_LOCAL=
# Schema name for the service (e.g., identity, market, guide_booking, map, ai)
DB_SCHEMA=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
MONGODB_PORT=27017
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# ==============================================================
# Redis
# ==============================================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=
# Leave empty in dev (no auth), set in prod

# ==============================================================
# Authentication
# ==============================================================
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=15d

# ==============================================================
# AI Service
# ==============================================================
MONGODB_URI=mongodb://username:password@localhost:27017/nakheel_db?authSource=admin
MONGODB_DB_NAME=nakheel_db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024
OPENAI_MAX_TOKENS=768
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT_SECONDS=60
TOKEN_BUDGET_CONTEXT=1600
QUERY_CACHE_SIZE=128
DENSE_TOP_K=5
SPARSE_TOP_K=5
RRF_TOP_N=5
RERANKER_TOP_K=3
RERANKER_MIN_CANDIDATES=6

# Optional fallback model keys retained for backward compatibility
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Qdrant
QDRANT_HOST=localhost
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_COLLECTION=nakheel_chunks
QDRANT_COLLECTION_NAME=hena_knowledge_base

# ==============================================================
# AWS S3
# ==============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=hena-wadeena-uploads
# Presigned URL expiry (seconds)
AWS_S3_PRESIGNED_URL_EXPIRES=3600

# ==============================================================
# Email (Resend)
# ==============================================================
# Get your key at https://resend.com — free tier: 3k/month
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=noreply@hena-wadeena.com

# ==============================================================
# Service Ports (for local dev without Docker)
# ==============================================================
WEB_PORT=8080
IDENTITY_PORT=8001
MARKET_PORT=8002
GUIDE_BOOKING_PORT=8003
MAP_PORT=8004
AI_PORT=8005
GATEWAY_PORT=8000
# Public reverse-proxy ports for the Caddy container in production.
# Change these if the host already uses 80/443.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Shared secret for service-to-service /internal/* endpoints
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=

# ==============================================================
# Internal service URLs (used by services to call each other)
# Ports must match *_PORT values above
# ==============================================================
IDENTITY_SERVICE_URL=http://identity:8001
MARKET_SERVICE_URL=http://market:8002
GUIDE_BOOKING_SERVICE_URL=http://guide-booking:8003
MAP_SERVICE_URL=http://map:8004
AI_SERVICE_URL=http://ai:8005

# ==============================================================
# Rate Limiting
# ==============================================================
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Login endpoint: stricter (5 attempts per 60s)
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=5

# ==============================================================
# Gateway (Nginx)
# ==============================================================
# CORS allowed origins — extra regex patterns on top of the hardcoded domains in nginx.conf.template
# Leave empty to only allow the hardcoded domains (hena-wadeena.online, localhost)
# Dev: .* (allow all)   Prod: leave empty or add specific extra patterns
CORS_ORIGINS=.*
# Max request body size (nginx client_max_body_size format: 1m, 10m, etc.)
MAX_BODY_SIZE=10m
# Max parsed request body size inside Nest/Express services (bytes format: 1mb, 10mb, etc.)
REQUEST_BODY_LIMIT=10mb
# Rate limits (nginx format: <number>r/m or <number>r/s)
# Global: applies to all non-auth, non-AI endpoints
RATE_GLOBAL=100r/m
# Auth: stricter limit for login/register/password-reset
RATE_AUTH=5r/m
# AI: moderate limit for chat/AI endpoints
RATE_AI=30r/m

# ==============================================================
# App
# ==============================================================
NODE_ENV=development
LOG_LEVEL=info
# Set to 1 when behind Nginx/ALB (required for correct IP in throttler)
TRUST_PROXY=1

# ==============================================================
# Seed
# ==============================================================
# Shared password for all seed accounts (used by pnpm db:seed)
SEED_PASSWORD=
