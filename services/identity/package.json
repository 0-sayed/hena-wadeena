{
  "name": "@hena-wadeena/identity",
  "version": "0.1.0",
  "private": true,
  "description": "Hena Wadeena — Identity Service",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "SERVICE_NAME=identity DB_SCHEMA=identity node --watch --env-file ../../.env --import tsx src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node --env-file ../../.env --import tsx src/db/migrate.ts",
    "db:seed": "node --env-file ../../.env --import tsx src/db/seed.ts",
    "db:seed:showcase": "node --env-file ../../.env --import tsx src/db/seed.ts --layer=showcase"
  },
  "dependencies": {
    "@hena-wadeena/nest-common": "workspace:*",
    "@hena-wadeena/types": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@node-rs/argon2": "^2.0.0",
    "axios": "^1.14.0",
    "drizzle-orm": "^0.38.0",
    "drizzle-zod": "^0.8.3",
    "ioredis": "^5.4.2",
    "ms": "^2.1.3",
    "nestjs-zod": "^5.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.9.3",
    "rxjs": "^7.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/ms": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "dotenv": "^16.0.0",
    "drizzle-kit": "0.30.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
